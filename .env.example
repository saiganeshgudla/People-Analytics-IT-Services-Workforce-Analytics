# ──────────────────────────────────────────────
# PeopleLens — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ──────────────────────────────────────────────

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=peoplelens
POSTGRES_USER=peoplelens_user
POSTGRES_PASSWORD=change_me_in_production

# Derived connection string (SQLAlchemy format)
DATABASE_URL=postgresql://peoplelens_user:change_me_in_production@localhost:5432/peoplelens

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=replace-with-a-random-256-bit-secret
API_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Environment: development | staging | production
ENV=development
DEBUG=true

# Data paths
DATA_DIR=data
SYNTHETIC_DATA_DIR=data/synthetic
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models

# Dashboard
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# dbt
DBT_PROFILES_DIR=dbt/peoplelens
DBT_PROJECT_DIR=dbt/peoplelens
